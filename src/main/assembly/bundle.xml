<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2
                              http://maven.apache.org/xsd/assembly-1.1.2.xsd">

    <id>proxy-bundle</id>
    <formats>
        <format>zip</format>
    </formats>

    <!-- Include proxy files -->
    <fileSets>
        <!-- Include apiproxy directory and all contents -->
        <fileSet>
            <directory>src/main/apigee/proxies</directory>
            <outputDirectory>apiproxy</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>

        <!-- Include policies -->
        <fileSet>
            <directory>src/main/apigee/policies</directory>
            <outputDirectory>apiproxy/policies</outputDirectory>
            <includes>
                <include>*.xml</include>
            </includes>
        </fileSet>

        <!-- Include target endpoints -->
        <fileSet>
            <directory>src/main/apigee/targets</directory>
            <outputDirectory>apiproxy/targets</outputDirectory>
            <includes>
                <include>*.xml</include>
            </includes>
        </fileSet>

        <!-- Include proxy endpoints -->
        <fileSet>
            <directory>src/main/apigee/resources</directory>
            <outputDirectory>apiproxy/resources</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
    </fileSets>

    <!-- Include individual files -->
    <files>
        <!-- Proxy manifest -->
        <file>
            <source>src/main/apigee/proxy.xml</source>
            <outputDirectory>apiproxy</outputDirectory>
            <destName>proxy.xml</destName>
        </file>
    </files>

</assembly>
